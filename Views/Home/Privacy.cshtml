@{
    ViewData["Title"] = "Política de Privacidad";
}

<h1>Política de Privacidad</h1>

<div class="privacy-grid">

    <div class="privacy-card">
        <h3>Protección de datos</h3>
        <p>
            La información de pacientes y médicos es utilizada únicamente
            para la gestión de citas y administración del sistema.
        </p>
    </div>

    <div class="privacy-card">
        <h3>Confidencialidad</h3>
        <p>
            Todos los datos almacenados deben ser tratados con absoluta
            confidencialidad y no podrán compartirse sin autorización.
        </p>
    </div>

    <div class="privacy-card">
        <h3>Integridad de la información</h3>
        <p>
            El sistema busca mantener actualizados los registros de pacientes,
            médicos y citas para evitar inconsistencias.
        </p>
    </div>

    <div class="privacy-card">
        <h3>Uso académico</h3>
        <p>
            Esta aplicación fue desarrollada con fines educativos para
            demostrar la implementación de un sistema web utilizando
            ASP.NET Core y archivos JSON.
        </p>
    </div>

</div>